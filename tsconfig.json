{
    "ts-node": {
        "require": ["tsconfig-paths/register"]
    },
    "compilerOptions": {
        "module": "commonjs",
        "target": "ESNext",
        "lib": ["ESNext", "decorators.legacy"],
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "types": ["node"],
        "baseUrl": ".",
        "typeRoots": ["node_modules/@types", "src/@types"],
        "paths": {
            "@/app/*": ["src/app/*"],
            "@/config/*": ["src/config/*"],
            "@/base/*": ["src/base/*"]
        }
    },
    "include": ["src/**/*"]
}
